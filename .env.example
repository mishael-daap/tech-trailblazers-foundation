# Cloudflare Turnstile Configuration
# Get your site key from: https://dash.cloudflare.com/ -> Turnstile -> Add Site
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Note: EmailJS credentials are currently hardcoded in src/pages/Contact.tsx
# To move them to environment variables, update Contact.tsx to use:
# VITE_EMAILJS_SERVICE_ID=your_service_id
# VITE_EMAILJS_TEMPLATE_ID_OWNER=your_owner_template_id
# VITE_EMAILJS_TEMPLATE_ID_USER=your_user_template_id
# VITE_EMAILJS_PUBLIC_KEY=your_public_key
